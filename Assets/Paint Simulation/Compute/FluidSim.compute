float PressureFromDensity(float density)
{
    return (density - targetDensity) * pressureMultiplier;
}

float NearPressureFromDensity(float nearDensity)
{
    return nearDensity * nearPressureMultiplier;
}


float Remap01(float val, float minVal, float maxVal)
{
    return saturate((val - minVal) / (maxVal - minVal));
}



void ResolveCollisions(uint particleID, inout float3 pos, inout float3 vel, float collisionDamping)
{
    // Skip already processed particles
    if (ParticleStates[particleID] == 1 || ParticleStates[particleID] == 2)
    {
        return;
    }
    
    float3 posLocal = mul(worldToLocal, float4(pos, 1)).xyz;
    float3 velocityLocal = mul(worldToLocal, float4(vel, 0)).xyz;

    const float bucketRadius = 0.5;
    float floorY = -1;
    const float ceilingY = 1.0;
    float horizontalDist = length(posLocal.xz);

    bool isOverHole = false;
    bool isAtSideHole = false;

    // Hole Detection Logic based on Orientation
      if (holeOrientation == 0) 
    {
        
        
        isOverHole = length(posLocal.xz - holePosition.xz) <= holeSize;
        
        //Hole is placed at the bottom floor, and particle falls below floor level
        if (isOverHole && holePosition.y <= floorY  && posLocal.y < floorY) 
        {
            ParticleStates[particleID] = 1; 
            return; 
        }
        
        //Hole is placed at the top ceiling, and particle pushes above ceiling level
        if (isOverHole && holePosition.y >= ceilingY  && posLocal.y > ceilingY) 
        {
            ParticleStates[particleID] = 1; 
            return; 
        }
    }
    else if (holeOrientation == 1)
    {

        bool withinVerticalHoleBounds = (posLocal.y >= holePosition.y - holeSize) && (posLocal.y <= holePosition.y + holeSize);

        float2 holeDir = normalize(holePosition.xz);

        float2 tangentDir = float2(-holeDir.y, holeDir.x);
        
        float distanceTowardsHole = dot(posLocal.xz, holeDir);

        float distanceBesideHole = abs(dot(posLocal.xz, tangentDir));

        bool withinHorizontalHoleBounds = (distanceTowardsHole > 0) && (distanceBesideHole <= holeSize);
        
        if (withinVerticalHoleBounds && withinHorizontalHoleBounds)
        {
            isAtSideHole = true;
        }
        

        if (isAtSideHole && horizontalDist >= bucketRadius)
        {
            ParticleStates[particleID] = 1; // Mark as out
            return;
        }
    }

    // Cylinder Wall Collision
    if (horizontalDist >= bucketRadius)
    {
        posLocal.xz = normalize(posLocal.xz) * bucketRadius;
        float2 wallNormal = normalize(posLocal.xz);
        float dotVel = dot(velocityLocal.xz, wallNormal);
        
        if (dotVel > 0)
        {
            velocityLocal.xz -= (1.0 + collisionDamping) * dotVel * wallNormal;
        }
    }

    // Ceiling Collision
    if (posLocal.y >= ceilingY)
    {
        if (!(holeOrientation == 0 && isOverHole))
        {
            posLocal.y = ceilingY;
            velocityLocal.y *= -1 * collisionDamping;
        }
    }
    // Floor Collision
    else if (posLocal.y <= floorY) 
    {
        posLocal.y = floorY;
        velocityLocal.y *= -1 * collisionDamping;
    }


    pos = mul(localToWorld, float4(posLocal, 1)).xyz;
    vel = mul(localToWorld, float4(velocityLocal, 0)).xyz;
}
